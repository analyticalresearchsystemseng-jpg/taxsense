default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build do
    # Setup App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      duration: 1200,
      in_house: false
    )

    # Generate or download certificates and provisioning profiles
    match(
      type: "appstore",
      app_identifier: "uk.co.taxsense.app",
      readonly: true,
      api_key: api_key,
      force_for_new_devices: false
    )

    # Set provisioning profile in Xcode project for archive step
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App/App.xcodeproj",
      team_id: ENV["ASC_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore uk.co.taxsense.app 1778177425",
      bundle_identifier: "uk.co.taxsense.app"
    )

    # Build and export with manual signing
    build_app(
      scheme: "App",
      project: "App/App.xcodeproj",
      export_method: "app-store",
      configuration: "Release",
      export_options: {
        provisioningProfiles: {
          "uk.co.taxsense.app" => "match AppStore uk.co.taxsense.app 1778177425"
        },
        signingStyle: "manual"
      }
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
