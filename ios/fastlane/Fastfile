default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build do
    # Setup App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      duration: 1200,
      in_house: false
    )

    # Get or create certificate
    cert(
      api_key: api_key,
      development: false
    )

    # Download or create provisioning profile via API
    sigh(
      api_key: api_key,
      app_identifier: "uk.co.taxsense.app",
      provisioning_name: "TaxSense App Store",
      force: true
    )

    # Update code signing to use the downloaded profile
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "App/App.xcodeproj",
      team_id: ENV["ASC_TEAM_ID"],
      code_sign_identity: "Apple Distribution",
      profile_name: "TaxSense App Store",
      bundle_identifier: "uk.co.taxsense.app"
    )

    # Build the app
    build_app(
      scheme: "App",
      project: "App/App.xcodeproj",
      export_method: "app-store",
      configuration: "Release"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
