default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build do
    # Get key content from environment variable
    key_content = ENV["ASC_KEY_P8"]
    
    if key_content.nil? || key_content.empty?
      UI.error("ASC_KEY_P8 environment variable not set!")
      exit 1
    end
    
    # Decode base64 key content
    require 'base64'
    decoded_key = Base64.decode64(key_content)
    
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: decoded_key,
      is_key_content_base64: false,
      in_house: false
    )

    # Build the app
    build_app(
      scheme: "App",
      workspace: "App.xcworkspace",
      export_method: "app-store",
      configuration: "Release",
      xcargs: "-allowProvisioningUpdates",
      build_path: "./build",
      output_directory: "./build"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
